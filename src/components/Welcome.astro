---
import FiltersApp from "./FiltersApp.jsx";
---

<div id="container">
	<main>
		<section id="hero" class="flex flex-col items-center justify-center min-h-screen">
			<h1 class="text-5xl font-bold modak-regular text-amber-800 text-center mt-10 text-shadow-md text-shadow-black">BarnaBiteRoulette</h1>
			<FiltersApp client:load />
		</section>
	</main>
</div>

<style>

	body{
		background: #fde4c8;
		
	}
	#container {
		font-family:
			Inter, Roboto, "Helvetica Neue", "Arial Nova", "Nimbus Sans", Arial,
			sans-serif;
		height: 100%;
		padding-bottom: 50px;
		
	}

	main {
		height: 100%;
		display: flex;
		justify-content: center;
	}

	#hero {
		display: flex;
		
		flex-direction: column;
		justify-content: center;
		padding: 16px;
	}

	/* h1 {
		margin-top: 0.25em;
	} */

	p {
		color: #4b5563;
		font-size: 16px;
		line-height: 24px;
		letter-spacing: -0.006em;
		margin: 0;
	}

	@media screen and (max-height: 368px) {
		#news {
			display: none;
		}
	}

	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
		}

		#hero {
			display: block;
			padding-top: 10%;
		}

		h1 {
			line-height: 1.5;
		}
	}
</style>
